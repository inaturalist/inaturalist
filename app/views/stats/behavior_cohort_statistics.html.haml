- content_for( :title ) do
  = @title = "Behavior Cohort Statistics"
- content_for( :extracss ) do
  :css
    :root {
      --cohort-border: #dde2ea;
      --cohort-header: #f6f8fb;
      --cohort-empty: #f1f3f6;
      --cohort-text: #1f2a44;
    }
    .cohort-stat-block {
      background: #fff;
      border: none;
      border-radius: 0;
      padding: 0;
      margin: 24px 0;
      box-shadow: none;
    }
    .cohort-stat-title {
      font-size: 22px;
      margin: 0 0 8px;
      color: var(--cohort-text);
    }
    .cohort-stat-subtitle {
      color: #5a6476;
      margin: 0 0 16px;
    }
    .cohort-stat-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid var(--cohort-border);
      padding-bottom: 12px;
      margin-bottom: 18px;
      font-size: 13px;
    }
    .cohort-nav-link {
      color: #2b6f3e;
      font-weight: 600;
      text-decoration: none;
    }
    .cohort-nav-link:hover {
      text-decoration: underline;
    }
    .cohort-nav-link.is-disabled {
      color: #9aa3b2;
      cursor: default;
      pointer-events: none;
      text-decoration: none;
    }
    .cohort-nav-date {
      color: #1f2a44;
      font-weight: 600;
    }
    .cohort-stat-meta {
      color: #7a859a;
      font-size: 12px;
    }
    .cohort-wide {
      max-width: 1700px;
      width: 100%;
    }
    .cohort-table-wrap {
      overflow-x: auto;
      border-radius: 10px;
      border: 1px solid var(--cohort-border);
    }
    .cohort-table {
      border-collapse: collapse;
      min-width: 1300px;
      width: 100%;
      font-size: 13px;
    }
    .cohort-table th,
    .cohort-table td {
      border: 1px solid var(--cohort-border);
      padding: 6px 8px;
      text-align: center;
      white-space: nowrap;
    }
    .cohort-table thead th {
      background: var(--cohort-header);
      font-weight: 600;
    }
    .cohort-row-title {
      text-align: left;
      background: #fff;
      position: sticky;
      left: 0;
      z-index: 2;
      min-width: 180px;
    }
    .cohort-row-label {
      font-weight: 600;
      color: var(--cohort-text);
    }
    .cohort-row-sub {
      color: #7a859a;
      font-size: 12px;
    }
    .cohort-cell {
      font-variant-numeric: tabular-nums;
      font-weight: 600;
    }
    .cohort-cell.is-empty {
      background: var(--cohort-empty);
      color: #9aa3b2;
      font-weight: 400;
    }

.container-fluid.cohort-wide
  %h1 Behavior Cohort Statistics
  .cohort-stat-nav
    - if @behavior_prev_record
      = link_to "Previous", behavior_cohort_statistics_stats_path( date: @behavior_prev_record.created_at.to_date ), class: "cohort-nav-link"
    - else
      %span.cohort-nav-link.is-disabled Previous
    - if @behavior_generated_at
      = link_to @behavior_generated_at.to_date.to_s, behavior_cohort_statistics_stats_path( date: @behavior_generated_at.to_date ), class: "cohort-nav-date"
    - else
      %span.cohort-nav-date No data
    - if @behavior_next_record
      = link_to "Next", behavior_cohort_statistics_stats_path( date: @behavior_next_record.created_at.to_date ), class: "cohort-nav-link"
    - else
      %span.cohort-nav-link.is-disabled Next

  .cohort-stat-block
    %p.cohort-stat-subtitle
      Retention by month for users first active in each cohort month.
      - if @behavior_generated_at
        %br/
        %span.cohort-stat-meta= "Data as of #{@behavior_generated_at.to_date}"
    - if @behavior_rows.blank?
      %p.cohort-stat-subtitle No data available.
    - else
      .cohort-table-wrap
        %table.cohort-table
          %thead
            %tr
              %th.cohort-row-title Cohort
              - @behavior_offsets.each do | offset |
                %th= offset
          %tbody
            - @behavior_rows.each do | row |
              %tr
                %th.cohort-row-title
                  %div.cohort-row-label= row[:label]
                  %div.cohort-row-sub= "#{number_with_delimiter( row[:cohort_count] )} users"
                - @behavior_offsets.each do | offset |
                  - cell = row[:behaviors_by_offset][offset]
                  - if cell
                    %td.cohort-cell{ style: cohort_cell_style( cell[:percent] ), title: "#{cohort_percent_label( cell[:percent] )} (#{number_with_delimiter( cell[:count] )} users)" }
                      = cohort_percent_label( cell[:percent] )
                  - else
                    %td.cohort-cell.is-empty -
