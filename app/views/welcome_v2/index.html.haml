-# ============================================================
-# Welcome v2 wireframe
-# All t() calls use full paths: views.welcome_v2.index.<section>.<key>
-# t(:key) for top-level shared labels (who, what, where, when, identify, etc.)
-# ============================================================
- content_for(:title) { t(:a_community_for_naturalist) }
- content_for(:extracss) { stylesheet_link_tag "welcome_v2" }
- content_for(:extrahead) { tag.link rel: "preload", href: asset_path("welcome_v2/hero_video_fallback.webp"), as: "image", type: "image/webp" }
- s = "views.welcome_v2.index"

.wv2
  -# ── Hero ──────────────────────────────────────────────────
  .wv2-section.wv2-section--hero.text-center
    %video.wv2-hero__video{autoplay: true, loop: true, muted: true, playsinline: true, preload: "none", aria: {hidden: "true"}}
      %source{data: {src: asset_path("welcome_v2/hero_video.webm")}, type: "video/webm"}
    :javascript
      (function() {
        var conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        console.log(conn);
        if (conn && (conn.saveData || /slow-2g|2g|3g/.test(conn.effectiveType))) return;
        var video = document.currentScript.previousElementSibling;
        if (!video) return;
        var source = video.querySelector("source");
        if (source && source.dataset.src) { source.src = source.dataset.src; video.load(); }
      })();
    .wv2-hero__content
      %h1= t("#{s}.hero.headline")
      %p.wv2-hero__sub= t("#{s}.hero.subheadline")
      = link_to t("#{s}.hero.cta_join"), signup_path, class: "btn wv2-btn--white btn-lg"
      %p.wv2-hero__tagline= t("#{s}.hero.tagline")

  -# ── "With iNaturalist you can" features ───────────────────
  .wv2-section.wv2-section--light.text-center
    %h2= t("#{s}.features.intro")
    .wv2-features
      - [[:identify, "identify_desc"], [:track, "track_desc"], [:discover, "discover_desc"], [:contribute, "contribute_desc"], [:learn, "learn_desc"]].each do |label_key, desc_key|
        .wv2-feature
          = image_tag "welcome_v2/#{label_key}.svg", class: "wv2-feature__icon", alt: ""
          %h3= t(label_key)
          %p= t("#{s}.features.#{desc_key}")

  -# ── Community science stories ─────────────────────────────
  .wv2-section.wv2-section--white.wv2-section--stories.text-center
    %h2= t("#{s}.stories.heading")
    .wv2-stories-row
      - [["moth_heading", "moth_body", "pav_johnsson", "New Zealand", {moth_common_name: "Frosted Phoenix"}, "frosted_phoenix"], ["mantis_heading", "mantis_body_html", "glendawalter", "Australia", {}, "inat"], ["amphibian_heading", "amphibian_body", "tcuriel", "United States", {}, "california_newt"]].each do |heading, body, user, place, interp, img|
        .wv2-story
          .wv2-story__image{style: "background-image: url(#{asset_path("welcome_v2/#{img}.webp")})"}
            %h3= t("#{s}.stories.#{heading}")
          .wv2-story__body
            %p= t("#{s}.stories.#{body}", interp)
            %p.wv2-story__credit= t("#{s}.stories.observation_credit", user: user, place: place)
    = link_to t("#{s}.stories.read_more"), "#", class: "btn wv2-btn--green"

  -# ── Sample observation ────────────────────────────────────
  -# TODO: wire up @sample_observation from controller (photo, map, who/what/where/when)
  .wv2-section.wv2-section--light.text-center
    %h2= t("#{s}.observation.heading")
    .wv2-observation
      .wv2-observation__col
        .wv2-observation__row
          %dt= t(:who)
          %dd.wv2-observation__who
            = image_tag "welcome_v2/tiwane.webp", class: "wv2-observation__avatar", alt: ""
            %span tiwane
        .wv2-observation__row.wv2-observation__row--sep
          %dt= t(:what)
          %dd
            = image_tag "welcome_v2/emerald_glass_frog.webp", class: "wv2-observation__photo", alt: ""
            .wv2-observation__taxon
              = image_tag "welcome_v2/little_emerald_glass_frog.webp", class: "wv2-observation__taxon-thumb", alt: ""
              .wv2-observation__taxon-names
                %p Emerald Glass Frog
                %em Espadarana prosoblepon
      .wv2-observation__col
        .wv2-observation__row
          %dt= t(:where)
          %dd
            = image_tag "welcome_v2/observation_example_map.webp", class: "wv2-observation__map", alt: ""
            .wv2-observation__place
              = image_tag "welcome_v2/icon-locationpin.svg", class: "wv2-observation__icon", alt: ""
              %span [place name]
        .wv2-observation__row.wv2-observation__row--sep
          %dt= t(:when)
          %dd
            .wv2-observation__date
              = image_tag "welcome_v2/icon-datetime.svg", class: "wv2-observation__icon", alt: ""
              %span [formatted date]

  -# ── Impact statistics ─────────────────────────────────────
  .wv2-section.wv2-section--white.wv2-section--stats.text-center
    .wv2-stats
      .wv2-stats__cell
        %p.wv2-stat__number
          = number_to_human(350_000_000, precision: 3, significant: false, strip_insignificant_zeros: true, units: { thousand: "K", million: "M", billion: "B" }, format: "%n%u")
          %span.wv2-stat__plus +
        %p.wv2-stat__label= t("#{s}.stats.observations_label")
      .wv2-stats__cell
        %p.wv2-stat__number
          = number_with_delimiter(550_000)
          %span.wv2-stat__plus +
        %p.wv2-stat__label= t("#{s}.stats.species_label")
      .wv2-stats__cell
        %p.wv2-stat__number
          = number_with_delimiter(7_000)
          %span.wv2-stat__plus +
        %p.wv2-stat__label= t("#{s}.stats.papers_label")
      .wv2-stats__cell
        %p.wv2-stat__number
          = number_with_delimiter(500)
          %span.wv2-stat__plus +
        %p.wv2-stat__label= t("#{s}.stats.discoveries_label")

  -# ── How it works ──────────────────────────────────────────
  .wv2-section.wv2-section--light.wv2-section--how
    .wv2-steps
      - [[:observe, "step1_body", "camera"], [:identify, "step2_body", "identify"], [:contribute, "step3_body", "globe"]].each_with_index do |(label_key, body_key, icon), i|
        .wv2-step
          %span.wv2-step__num= i + 1
          .wv2-step__content
            .wv2-step__heading
              %h3= t(label_key)
              = image_tag "welcome_v2/icon-#{icon}.svg", class: "wv2-step__icon", alt: ""
            %p= t("#{s}.how.#{body_key}")

  -# ── Why ───────────────────────────────────────────────────
  .wv2-section.wv2-section--white
    .wv2-why
      %strong.wv2-why__label Why?
      %p.wv2-why__body= t("#{s}.how.why_note_html")

  -# ── Testimonials ──────────────────────────────────────────
  .wv2-section.wv2-section--white
    .wv2-testimonials
      - {gube: "Dzivula Gube", kratzer: "Chris Alice \"Alie\" Kratzer", sumanapala: "Amila Sumanapala", fachetti: "Nágyla Fachetti", velazco: "Carlos G. Velazco Macias"}.each do |key, name|
        .wv2-testimonial
          .wv2-testimonial__quote
            %p= t("#{s}.testimonials.#{key}_quote")
          .wv2-testimonial__byline
            .wv2-testimonial__avatar
            %div
              %p.wv2-testimonial__name= name
              %p.wv2-testimonial__title= t("#{s}.testimonials.#{key}_title")

  -# ── Everyone is a naturalist ──────────────────────────────
  .wv2-section.wv2-section--light
    .wv2-everyone
      .wv2-everyone__point
        %h3= t("#{s}.everyone.heading")
        %p= t("#{s}.everyone.body")
      .wv2-everyone__point
        %h3= t("#{s}.everyone.impact_heading")
        %p= t("#{s}.everyone.impact_body")
      .wv2-everyone__point
        %h3= t("#{s}.everyone.community_heading")
        %p= t("#{s}.everyone.community_body")

  -# ── App download ──────────────────────────────────────────
  .wv2-section.wv2-section--white.wv2-section--spacious
    .wv2-download
      .wv2-download__copy.text-center
        %h2= t("#{s}.download.heading")
        .wv2-download__body
          %p= t("#{s}.download.subheading")
          .wv2-store-badges
            = link_to "https://itunes.apple.com/app/inaturalist/id6475737561", target: "_blank", rel: "noopener" do
              = image_tag "https://static.inaturalist.org/wiki_page_attachments/414-original.png", alt: "Download on the App Store", class: "wv2-store-badge"
            = link_to "https://play.google.com/store/apps/details?id=org.inaturalist.android", target: "_blank", rel: "noopener" do
              = image_tag "https://static.inaturalist.org/wiki_page_attachments/412-original.png", alt: "Get it on Google Play", class: "wv2-store-badge"
          %p.wv2-download__count= t("#{s}.download.count_label", count: number_with_delimiter(700_000))
      .wv2-download__images
        = image_tag "welcome_v2/inaturalist.webp", class: "wv2-download__phone", alt: "iNaturalist app"

  -# ── Explore species ───────────────────────────────────────
  -# TODO: wire up @explore_observations from static JSON (config/welcome_v2/explore_observations.json)
  .wv2-section.wv2-section--light.text-center
    %h2= t("#{s}.explore.heading")
    .wv2-explore__cards
      - [ {username: "sea-kangaroo",   common: "Light-blue Soldier Crab", sci: "Mictyris longicarpus",    location: "Urangan, Queensland, Australia"} ].each do |obs|
        .wv2-obs-card
          .wv2-obs-card__header
            .wv2-obs-card__avatar
            %span.wv2-obs-card__username= obs[:username]
          .wv2-obs-card__photo
          .wv2-obs-card__taxon
            .wv2-obs-card__taxon-thumb
            .wv2-obs-card__taxon-names
              - if obs[:common]
                %p.wv2-obs-card__common= obs[:common]
              %p.wv2-obs-card__sci= obs[:sci]
          .wv2-obs-card__location
            = image_tag "welcome_v2/icon-locationpin.svg", class: "wv2-obs-card__location-icon", alt: ""
            %span= obs[:location]
    = link_to t("#{s}.explore.button"), observations_path, class: "btn wv2-btn--dark"

  -# ── Seek ──────────────────────────────────────────────────
  .wv2-section.wv2-section--white.wv2-section--spacious
    .wv2-seek
      .wv2-seek__images
        = image_tag "welcome_v2/seek.webp", class: "wv2-seek__phone", alt: "Seek app"
      .wv2-seek__copy.text-center
        %h2= t("#{s}.seek.heading")
        .wv2-seek__body
          %p= t("#{s}.seek.body")
          .wv2-store-badges
            = link_to "https://itunes.apple.com/app/seek-by-inaturalist/id1353224144", target: "_blank", rel: "noopener" do
              = image_tag "https://static.inaturalist.org/wiki_page_attachments/414-original.png", alt: "Download on the App Store", class: "wv2-store-badge"
            = link_to "https://play.google.com/store/apps/details?id=org.inaturalist.seek", target: "_blank", rel: "noopener" do
              = image_tag "https://static.inaturalist.org/wiki_page_attachments/412-original.png", alt: "Get it on Google Play", class: "wv2-store-badge"
          %p.wv2-seek__reviews= t("#{s}.seek.review_tagline", count: number_with_delimiter(20_000))

  -# ── Newsletter ────────────────────────────────────────────
  .wv2-section.wv2-section--dark.wv2-section--spacious.text-center
    %h2= t("#{s}.newsletter.heading")
    %p= t("#{s}.newsletter.body")
    = link_to t(:sign_up_sentence_case), "/pages/newsletter", class: "btn wv2-btn--white"

  -# ── Donate ────────────────────────────────────────────────
  .wv2-section.wv2-section--white.wv2-section--spacious.text-center
    %p.wv2-donate__headline= t("#{s}.donate.heading")
    %p= t("#{s}.donate.subheading")
    = link_to t("#{s}.donate.cta"), donate_path, class: "btn wv2-btn--green"

  -# ── FAQ ───────────────────────────────────────────────────
  .wv2-section.wv2-section--light
    %h2.text-center= t("#{s}.faq.heading")
    .wv2-faq
      - %w[upload_existing who_can_use research_grade no_knowledge need_app].each do |key|
        %details.wv2-faq__item
          %summary= t("#{s}.faq.#{key}_question")
          %p= t("#{s}.faq.#{key}_answer")
