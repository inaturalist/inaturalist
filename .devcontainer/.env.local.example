# Copy this file to `.env.local` (same directory) and fill in the values.
# `.env.local` is gitignored and is loaded into the sandbox container on every
# launch via --env-file in devcontainer.json — set these once, no re-exporting.
#
# Format: KEY=value, one per line, NO quotes, NO surrounding spaces.

# Anthropic auth: ~/.claude is mounted from the host (see devcontainer.json),
# so no Claude token is needed here — Claude Code uses your Team subscription credentials
# with automatic refresh.

# A DEDICATED read-only GitHub fine-grained PAT (github.com/settings/tokens).
# Read-only perms only: Contents, Metadata, Pull requests, Issues, Actions.
# Do NOT paste your normal write-capable gh token here.
GH_TOKEN=

# A read-only Linear personal API key (Linear → Settings → Account → Security &
# Access → new personal API key, scope = Read only, optionally limited to teams).
# Used by the Linear MCP (see README). Leave blank if you don't use Linear.
LINEAR_API_KEY=

# Postgres host — the Rails app (database.yml) reads this to find the database.
# In the devcontainer, Postgres runs on the Docker host; host.docker.internal is
# wired to the host gateway via --add-host in devcontainer.json.
INAT_DB_HOST=host.docker.internal

# Elasticsearch host — same pattern as INAT_DB_HOST above.
INAT_ES_HOST=host.docker.internal
